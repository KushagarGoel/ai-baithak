# ============================================
# LiteLLM Proxy Configuration
# ============================================
# Your personal LiteLLM proxy - all models use this single URL and key
# Configure your models in LiteLLM, then reference them by name below

LITELLM_PROXY_URL=http://localhost:4000
LITELLM_PROXY_KEY=your-proxy-api-key

# ============================================
# Example: 10 Models via LiteLLM Proxy
# ============================================
# Reference these model names in your agent configuration:
# - gpt-4o
# - gpt-4o-mini
# - claude-3-opus
# - claude-3-sonnet
# - claude-3-haiku
# - gemini-1.5-pro
# - gemini-1.5-flash
# - llama-3-70b
# - mixtral-8x22b
# - command-r-plus
#
# Use whatever model names you've configured in your LiteLLM proxy
